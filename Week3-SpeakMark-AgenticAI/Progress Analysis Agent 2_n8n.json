    {
      "parameters": {
        "jsCode": "const webhookData = $('Webhook').item.json.body;\nconst logRows = $('Read Practice_Log').all();\n\n// Sort log by Session_ID descending, take last 10\nconst sortedLog = logRows\n  .map(r => r.json)\n  .filter(r => r.Child_Name === webhookData.child)\n  .sort((a, b) => Number(b.Session_ID?.replace('S','')) - Number(a.Session_ID?.replace('S','')))\n  .slice(0, 10);\n\nconst newSession = {\n  session_date:  webhookData.session_date,\n  duration_mins: webhookData.duration_mins,\n  difficulty:    webhookData.difficulty,\n  accuracy_pct:  webhookData.accuracy_pct,\n  target_sounds: webhookData.target_sounds,\n  notes:         webhookData.notes,\n};\n\nreturn [{\n  json: {\n    child:          webhookData.child,\n    profile:        {},\n    newSession,\n    recentSessions: sortedLog,\n    webhookData,\n  }\n}];"
      },
      "id": "f856442d-86bb-4267-8e90-e7e9fb4ed6f1",
      "name": "Merge Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -544,
        32
      ]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "claude-sonnet-4-6",
          "mode": "list",
          "cachedResultName": "claude-sonnet-4-6"
        },
        "messages": {
          "values": [
            {
              "content": "=You are SpeakMark's Progress Analysis Agent for children's speech therapy home practice.\n\nYour job:\n1. Analyse the child's recent practice sessions\n2. Classify the overall trend\n3. Recommend an action for the parent\n4. Decide if a difficulty level change is warranted\n\nChild profile:\n{{ JSON.stringify($('Merge Data').item.json.profile) }}\n\nNew session just logged:\n{{ JSON.stringify($('Merge Data').item.json.newSession) }}\n\nLast 10 sessions (most recent first):\n{{ JSON.stringify($('Merge Data').item.json.recentSessions) }}\n\nRespond ONLY in this exact JSON format (no markdown, no extra text):\n{\n  \"trend\": \"Improving\" | \"Stable\" | \"Struggling\" | \"Possible Regression\",\n  \"recommendation\": \"Keep current exercises\" | \"Increase difficulty\" | \"Reduce difficulty\" | \"Try alternative exercise\" | \"Therapist review recommended\",\n  \"needs_hitl_approval\": true | false,\n  \"proposed_level\": \"Sound\" | \"Word\" | \"Phrase\" | \"Sentence\",\n  \"analysis\": \"2-4 sentence plain-English explanation for the parent\",\n  \"decision_notes\": \"Internal reasoning for the log\",\n  \"escalate_to_therapist\": true | false\n}\n\nRules:\n- needs_hitl_approval = true ONLY when recommending a difficulty change\n- proposed_level = current level when no change recommended\n- escalate_to_therapist = true when accuracy below 40% for 3+ sessions OR Possible Regression"
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [
        -384,
        32
      ],
      "id": "2e53c749-c676-4bd7-b526-69f7e27c8d6f",
