      "credentials": {
        "anthropicApi": {
          "id": "yzHAWxvsqaBuHu6B",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.content[0].text.trim();\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = match ? JSON.parse(match[0]) : {};\n}\n\nconst webhook = $('Webhook').item.json.body;\n\nreturn [{\n  json: {\n    Session_ID:            `S${Date.now()}`,\n    Child_ID:              webhook.child,\n    Child_Name:            webhook.child,\n    Date:                  webhook.session_date,\n    Practice_Level:        webhook.difficulty,\n    Target_Sound:          webhook.target_sounds,\n    Duration_Minutes:      webhook.duration_mins,\n    Raw_Parent_Note:       webhook.notes,\n    Practice_Rating_Score: webhook.accuracy_pct,\n    Practice_Completed:    'Yes',\n    Agent_Decision:        parsed.recommendation || '',\n    Escalation_Flag:       parsed.escalate_to_therapist ? 'Yes' : 'No',\n    HITL_Status:           parsed.needs_hitl_approval ? 'Pending' : 'N/A',\n  }\n}];"
      },
