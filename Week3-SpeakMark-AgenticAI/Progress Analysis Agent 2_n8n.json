      "parameters": {
        "jsCode": "const prev = $('Code in JavaScript').first().json;\nconst webhook = $('Webhook').item.json.body;\n\nconst raw = $('Message a model').first().json.content[0].text.trim();\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = match ? JSON.parse(match[0]) : {};\n}\n\nconst now = new Date().toISOString().slice(0, 10);\n\nreturn [{\n  json: {\n    Decision_ID:             `D${Date.now()}`,\n    Child_ID:                webhook.child,\n    Date:                    now,\n    Agent_Name:              'Progress_Analysis',\n    Observation:             parsed.analysis || '',\n    Decision:                parsed.recommendation || '',\n    Reason:                  parsed.decision_notes || '',\n    Confidence:              'High',\n    Human_Approval_Required: parsed.needs_hitl_approval ? 'Yes' : 'No',\n    Parent_Response:         parsed.needs_hitl_approval ? 'Pending' : 'N/A',\n    Write_Action:            parsed.proposed_level || webhook.difficulty,\n    Status:                  parsed.escalate_to_therapist ? 'Escalate' : 'Active',\n  }\n}];"
      },
